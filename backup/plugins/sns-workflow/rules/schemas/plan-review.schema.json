{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plan Review Result",
  "type": "object",
  "required": ["id", "reviewer", "model", "revision_number", "status", "needs_clarification", "clarification_questions", "summary", "findings", "requirements_coverage", "reviewed_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique review identifier (e.g., 'review-20260315-143022')"
    },
    "reviewer": {
      "type": "string",
      "description": "System prompt name of the reviewer agent, used for re-dispatch routing on re-review"
    },
    "model": {
      "type": "string",
      "description": "Model identifier used for this review (e.g., 'sonnet', 'qwen3.5-plus')"
    },
    "revision_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Revision counter — starts at 1, incremented on each re-review after fixes"
    },
    "status": {
      "type": "string",
      "enum": ["approved", "needs_changes", "needs_clarification", "rejected"],
      "description": "Overall plan review decision"
    },
    "requirements_coverage": {
      "type": "object",
      "description": "Maps each acceptance criterion from user-story.json to plan steps that address it",
      "required": ["mapping", "missing"],
      "properties": {
        "mapping": {
          "type": "array",
          "description": "Array of AC-to-steps mappings",
          "items": {
            "type": "object",
            "required": ["ac_id", "steps"],
            "properties": {
              "ac_id": {
                "type": "string",
                "description": "Acceptance criterion ID (e.g., 'AC1')"
              },
              "steps": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Plan step(s) that address this AC"
              }
            },
            "additionalProperties": false
          }
        },
        "missing": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of AC IDs not covered by the plan"
        }
      },
      "additionalProperties": false
    },
    "needs_clarification": {
      "type": "boolean",
      "default": false,
      "description": "If true, pauses autonomous workflow to ask user for clarification on ambiguous requirements"
    },
    "clarification_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Questions to ask user when needs_clarification is true"
    },
    "summary": {
      "type": "string",
      "description": "Brief overall assessment of the plan"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "area", "message", "suggestion", "fix_type", "contract_reference", "evidence"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"],
            "description": "How serious the finding is"
          },
          "area": {
            "type": "string",
            "enum": ["requirements", "approach", "architecture", "complexity", "risks", "feasibility", "security", "quality"],
            "description": "Which aspect of the plan the finding relates to"
          },
          "message": {
            "type": "string",
            "description": "Description of the finding"
          },
          "suggestion": {
            "type": "string",
            "description": "How to address this finding"
          },
          "contract_reference": {
            "type": "string",
            "description": "Reference to the contract item this finding relates to (e.g., 'AC3', 'plan-step-2', 'security-rule')"
          },
          "evidence": {
            "type": "string",
            "description": "Specific code reference or file:line proving the finding"
          },
          "fix_type": {
            "type": "string",
            "enum": ["must_fix", "advisory"],
            "description": "Whether this finding blocks approval (must_fix) or is informational (advisory)"
          }
        },
        "additionalProperties": false
      },
      "description": "List of findings from the review. needs_changes requires at least one must_fix finding with evidence."
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of when review was completed"
    }
  },
  "additionalProperties": false
}
