{
  "description": "sns-workflow hooks（doc-garden + drift-scanner + prompt-optimize）",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/skills/prompt-optimize/bin/user-prompt-submit.sh"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/doc-garden/bin/check-doc-arch.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/drift-scanner/bin/scan-on-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/doc-garden/bin/remind-doc-update.sh"
          }
        ]
      }
    ]
  }
}
